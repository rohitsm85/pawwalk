rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is logged in
    function isSignedIn() {
      return request.auth != null;
    }

    // 1. Users Collection: Only the user can read/write their own profile
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // 2. Dogs Collection: Anyone logged in can see dogs, 
    // but only the owner can add/edit them.
    match /dogs/{dogId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    // 3. Walks Collection: Authenticated users can create/view walks
    match /walks/{walkId} {
      allow read, write: if isSignedIn();
    }
  }
}